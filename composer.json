{
    "name": "gestion-comptable/app",
    "description": "Application de gestion comptable pour PME suisses",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=7.4",
        "endroid/qr-code": "^4.8",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^6.9",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\Models\\": "models/",
            "App\\Controllers\\": "controllers/",
            "App\\Utils\\": "utils/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
